{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://z.dev/protocol/ipc-v0.json",
  "title": "Z Editor ↔ z-app-server IPC v0",
  "description": "JSON-RPC 2.0 over local WebSocket. Inspired by Codex app-server Thread/Turn lifecycle; payloads are Z-native.",
  "transport": {
    "default": "ws://127.0.0.1:8741",
    "env": "Z_APP_SERVER_URL"
  },
  "handshake": ["initialize", "initialized"],
  "methods": {
    "initialize": {
      "params": {
        "clientInfo": { "name": "string", "version": "string" },
        "workspaceRoot": { "type": "string", "optional": true }
      },
      "result": {
        "serverInfo": { "name": "z-app-server", "version": "string" },
        "zHome": "string",
        "capabilities": ["uncertainty", "skills", "commit_blocks", "mcp", "turns", "auth", "workspace"]
      }
    },
    "server/health": {
      "params": {},
      "result": { "ok": true, "initialized": "boolean", "pid": "number" },
      "notes": "Allowed before initialize — used by spawn/attach probe."
    },
    "workspace/open": {
      "params": { "root": "string" },
      "result": { "ok": true, "root": "string" }
    },
    "workspace/info": {
      "params": {},
      "result": { "root": "string|null", "open": "boolean", "name": "string|null" }
    },
    "turn/start": {
      "params": {
        "threadId": "string",
        "text": "string"
      },
      "result": {
        "turnId": "string",
        "accepted": true,
        "queued": "boolean",
        "queueLen": { "optional": true },
        "items": { "optional": true, "type": "string[]" },
        "preview": { "optional": true }
      },
      "notes": "Phase 4 — runs Coder.run(with_message) on a worker thread; if busy, enqueues and returns queued+preview (Cursor-style)."
    },
    "turn/respond": {
      "params": {
        "requestId": "string",
        "response": "string|boolean",
        "text": { "optional": true },
        "threadId": { "optional": true }
      },
      "result": { "ok": true }
    },
    "turn/cancel": {
      "params": { "threadId": { "optional": true } },
      "result": { "ok": true }
    },
    "uncertainty/list": {
      "params": {
        "sort": { "enum": ["risk", "age", "type", "status"], "default": "risk" },
        "includeResolved": { "type": "boolean", "default": false },
        "status": { "optional": true }
      },
      "result": {
        "nodes": "UncertaintyNode[] (with resolution_contract)",
        "subscribed": "boolean"
      },
      "notes": "Phase 6 — chain view payload includes ResolutionContract."
    },
    "uncertainty/subscribe": {
      "params": {},
      "result": { "ok": true, "subscribed": true },
      "notes": "Phase 6 — live uncertainty/upsert on store mutations."
    },
    "uncertainty/unsubscribe": {
      "params": {},
      "result": { "ok": true, "subscribed": false }
    },
    "skills/list": {
      "params": {
        "kind": { "optional": true },
        "quality_state": { "optional": true },
        "needs_review": { "optional": true },
        "query": { "optional": true }
      },
      "result": { "skills": "SkillSummary[]" }
    },
    "skills/get": {
      "params": { "id": "string" },
      "result": { "skill": "Skill" }
    },
    "skills/create": {
      "params": {
        "skill": "SkillDraft",
        "force": { "optional": true },
        "merge": { "optional": true }
      },
      "result": {
        "created": "boolean",
        "merged": "boolean",
        "skill": "Skill|null",
        "near_dup": { "optional": true },
        "draft": { "optional": true }
      },
      "notes": "Phase 7 — always draft / needs_review (D8); near-dup blocks unless force|merge."
    },
    "commit_blocks/list": {
      "params": {},
      "result": {
        "blocks": "CommitBlockRecord[]",
        "blockedCount": "number",
        "canCommit": "boolean"
      }
    },
    "commit_blocks/override": {
      "params": {
        "id": "string",
        "confirm": true,
        "reason": { "optional": true }
      },
      "result": { "ok": true, "block": "CommitBlockRecord" },
      "notes": "Phase 8 — confirm=true required (never one-click)."
    },
    "commit_blocks/resolve": {
      "params": { "id": "string", "note": { "optional": true } },
      "result": { "ok": true, "block": "CommitBlockRecord" }
    },
    "mcp/list": {
      "params": {},
      "result": { "connections": "McpConnectionSummary[]" },
      "notes": "Phase 10 — merge local ~/.z/mcp store with cloud runtime."
    },
    "mcp/catalog": {
      "params": {},
      "result": { "catalog": "McpCatalogEntry[]" }
    },
    "mcp/connect": {
      "params": {
        "serverName": "string",
        "credentials": { "optional": true },
        "config": { "optional": true },
        "displayName": { "optional": true },
        "syncCloud": { "optional": true, "default": true }
      },
      "result": { "connection": "McpConnectionSummary", "updated": "boolean", "test": "object" }
    },
    "mcp/disconnect": {
      "params": { "id": "string" },
      "result": { "ok": true }
    },
    "mcp/test": {
      "params": {
        "id": { "optional": true },
        "serverName": { "optional": true },
        "credentials": { "optional": true },
        "skipPersist": { "optional": true, "default": true }
      },
      "result": { "ok": "boolean", "error": { "optional": true } }
    },
    "mcp/confirmFirstUse": {
      "params": {
        "serverName": "string",
        "toolName": { "optional": true, "default": "*" },
        "forever": { "optional": true, "default": true }
      },
      "result": { "ok": true },
      "notes": "D9 — persist first-use trust for MCP tools."
    },
    "mcp/firstUseStatus": {
      "params": {
        "serverName": "string",
        "toolName": { "optional": true, "default": "*" }
      },
      "result": { "needsConfirm": "boolean", "confirmed": "boolean" }
    },
    "mcp/sync": {
      "params": {},
      "result": { "ok": "boolean", "synced": "number", "skipped": "number" }
    },
    "mcp/tools": {
      "params": { "id": { "optional": true } },
      "result": { "tools": "McpToolDesc[]" },
      "notes": "Phase 11 — list tools (cached index or live session)."
    },
    "mcp/oauthStart": {
      "params": { "serverName": "string", "scope": { "optional": true, "default": "personal" } },
      "result": { "authorizeUrl": "string", "serverName": "string" },
      "notes": "Phase 13 — desktop OAuth; callback redirects to z-editor://mcp/oauth/done."
    },
    "usage/summary": {
      "params": { "range": { "enum": ["billing_period", "all"], "default": "billing_period" } },
      "result": {
        "byModel": "UsageRow[]",
        "totalRequests": "number",
        "totalCostUsd": "number",
        "authenticated": "boolean",
        "source": "string"
      },
      "notes": "Phase 9/14 — live gateway usage when authenticated; empty (not demo) when unsigned-in."
    },
    "auth/status": {
      "params": {},
      "result": {
        "authenticated": "boolean",
        "email": { "optional": true },
        "auth_mode": { "enum": ["router", "byok", null] },
        "login": { "optional": true }
      }
    },
    "auth/loginStart": {
      "params": {
        "method": { "enum": ["google", "z"] },
        "intent": { "enum": ["signin", "signup"], "default": "signin" },
        "openBrowser": { "type": "boolean", "default": false }
      },
      "result": {
        "started": true,
        "loginUrl": "string",
        "state": "string",
        "status": "pending"
      },
      "notes": "Phase 3 — non-blocking; extension opens loginUrl via openExternal."
    },
    "auth/loginStatus": {
      "params": {},
      "result": { "status": { "enum": ["idle", "pending", "succeeded", "failed", "cancelled"] } }
    },
    "auth/loginCancel": {
      "params": {},
      "result": { "status": "cancelled" }
    },
    "auth/logout": {
      "params": {},
      "result": { "ok": true, "authenticated": false }
    }
  },
  "notifications": {
    "turn/started": {
      "turnId": "string",
      "threadId": "string",
      "text": { "optional": true },
      "fromQueue": { "optional": true }
    },
    "turn/busy": {
      "turnId": "string",
      "state": { "enum": ["idle", "busy", "waiting_input"] },
      "phase": "string",
      "label": "string",
      "queueLen": "number"
    },
    "item/agentMessage/delta": { "turnId": "string", "text": "string" },
    "turn/log": { "turnId": "string", "level": "info|warning|error", "text": "string" },
    "turn/queued": {
      "turnId": "string",
      "queueLen": "number",
      "items": "string[]",
      "preview": "string|null"
    },
    "turn/error": { "turnId": "string", "message": "string" },
    "uncertainty/upsert": { "node": "UncertaintyNode" },
    "uncertainty/changed": { "turnId": { "optional": true }, "reason": "string" },
    "gate/commit_blocked": { "record": "CommitBlockRecord" },
    "gate/commit_updated": {
      "record": "CommitBlockRecord",
      "action": { "enum": ["overridden", "resolved"] }
    },
    "turn/waiting_input": {
      "turnId": "string",
      "requestId": "string",
      "kind": { "enum": ["confirm", "plan_confirm", "prompt", "mcp_tool"] },
      "question": "string",
      "subject": { "optional": true },
      "options": { "optional": true },
      "default": { "optional": true }
    },
    "mcp/tool_started": {
      "turnId": "string",
      "serverName": "string",
      "toolName": "string",
      "callId": "string"
    },
    "mcp/tool_finished": {
      "turnId": "string",
      "callId": "string",
      "serverName": "string",
      "toolName": "string",
      "ok": true,
      "summary": { "optional": true },
      "durationMs": "number"
    },
    "mcp/tool_error": {
      "turnId": "string",
      "callId": "string",
      "serverName": "string",
      "toolName": "string",
      "error": "string"
    },
    "turn/completed": {
      "turnId": "string",
      "threadId": "string",
      "ok": "boolean",
      "interrupted": "boolean"
    }
  },
  "deepLinks": {
    "protocol": "z-editor",
    "examples": [
      "z-editor://signin?method=google",
      "z-editor://signin?method=z",
      "z-editor://auth/complete"
    ]
  }
}
