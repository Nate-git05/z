{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://z.dev/protocol/ipc-v0.json",
  "title": "Z Editor ↔ z-app-server IPC v0",
  "description": "JSON-RPC 2.0 over local WebSocket. Inspired by Codex app-server Thread/Turn lifecycle; payloads are Z-native.",
  "transport": {
    "default": "ws://127.0.0.1:8741",
    "env": "Z_APP_SERVER_URL"
  },
  "handshake": ["initialize", "initialized"],
  "methods": {
    "initialize": {
      "params": {
        "clientInfo": { "name": "string", "version": "string" },
        "workspaceRoot": { "type": "string", "optional": true }
      },
      "result": {
        "serverInfo": { "name": "z-app-server", "version": "string" },
        "zHome": "string",
        "capabilities": ["uncertainty", "skills", "commit_blocks", "mcp", "turns", "auth", "workspace"]
      }
    },
    "server/health": {
      "params": {},
      "result": { "ok": true, "initialized": "boolean", "pid": "number" },
      "notes": "Allowed before initialize — used by spawn/attach probe."
    },
    "workspace/open": {
      "params": { "root": "string" },
      "result": { "ok": true, "root": "string" }
    },
    "workspace/info": {
      "params": {},
      "result": { "root": "string|null", "open": "boolean", "name": "string|null" }
    },
    "turn/start": {
      "params": {
        "threadId": "string",
        "text": "string"
      },
      "result": { "turnId": "string", "accepted": true, "queued": "boolean" },
      "notes": "Phase 4 — runs Coder.run(with_message) on a worker thread; streams turn/* notifications."
    },
    "turn/respond": {
      "params": {
        "requestId": "string",
        "response": "string|boolean",
        "text": { "optional": true },
        "threadId": { "optional": true }
      },
      "result": { "ok": true }
    },
    "turn/cancel": {
      "params": { "threadId": { "optional": true } },
      "result": { "ok": true }
    },
    "uncertainty/list": {
      "params": {
        "sort": { "enum": ["risk", "age", "type"], "default": "risk" }
      },
      "result": { "nodes": "UncertaintyNode[]" }
    },
    "skills/list": {
      "params": {
        "kind": { "optional": true },
        "quality_state": { "optional": true },
        "query": { "optional": true }
      },
      "result": { "skills": "SkillSummary[]" }
    },
    "skills/create": {
      "params": { "skill": "SkillDraft" },
      "result": { "skill": "Skill" },
      "notes": "Always draft / needs_review (D8)."
    },
    "commit_blocks/list": {
      "params": {},
      "result": { "blocks": "CommitBlockRecord[]" }
    },
    "mcp/list": {
      "params": {},
      "result": { "connections": "McpConnectionSummary[]" }
    },
    "usage/summary": {
      "params": { "range": { "enum": ["billing_period", "all"], "default": "billing_period" } },
      "result": { "byModel": "UsageRow[]" },
      "notes": "Proxies gateway /v1/gateway/usage when authenticated."
    },
    "auth/status": {
      "params": {},
      "result": {
        "authenticated": "boolean",
        "email": { "optional": true },
        "auth_mode": { "enum": ["router", "byok", null] },
        "login": { "optional": true }
      }
    },
    "auth/loginStart": {
      "params": {
        "method": { "enum": ["google", "z"] },
        "intent": { "enum": ["signin", "signup"], "default": "signin" },
        "openBrowser": { "type": "boolean", "default": false }
      },
      "result": {
        "started": true,
        "loginUrl": "string",
        "state": "string",
        "status": "pending"
      },
      "notes": "Phase 3 — non-blocking; extension opens loginUrl via openExternal."
    },
    "auth/loginStatus": {
      "params": {},
      "result": { "status": { "enum": ["idle", "pending", "succeeded", "failed", "cancelled"] } }
    },
    "auth/loginCancel": {
      "params": {},
      "result": { "status": "cancelled" }
    },
    "auth/logout": {
      "params": {},
      "result": { "ok": true, "authenticated": false }
    }
  },
  "notifications": {
    "turn/started": { "turnId": "string", "threadId": "string" },
    "turn/busy": {
      "turnId": "string",
      "state": { "enum": ["idle", "busy", "waiting_input"] },
      "phase": "string",
      "label": "string",
      "queueLen": "number"
    },
    "item/agentMessage/delta": { "turnId": "string", "text": "string" },
    "turn/log": { "turnId": "string", "level": "info|warning|error", "text": "string" },
    "turn/queued": { "turnId": "string", "queueLen": "number" },
    "turn/error": { "turnId": "string", "message": "string" },
    "uncertainty/upsert": { "node": "UncertaintyNode" },
    "gate/commit_blocked": { "record": "CommitBlockRecord" },
    "turn/waiting_input": {
      "turnId": "string",
      "requestId": "string",
      "kind": { "enum": ["confirm", "plan_confirm", "prompt"] },
      "question": "string",
      "subject": { "optional": true },
      "options": { "optional": true },
      "default": { "optional": true }
    },
    "turn/completed": {
      "turnId": "string",
      "threadId": "string",
      "ok": "boolean",
      "interrupted": "boolean"
    }
  },
  "deepLinks": {
    "protocol": "z-editor",
    "examples": [
      "z-editor://signin?method=google",
      "z-editor://signin?method=z",
      "z-editor://auth/complete"
    ]
  }
}
