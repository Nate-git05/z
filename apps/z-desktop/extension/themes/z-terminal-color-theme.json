    "peekView.border": "#F7A56B",
    "peekViewEditor.background": "#161412",
    "peekViewResult.background": "#0E0D0C",
    "peekViewTitle.background": "#161412"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#C98858" }
    },
    {
      "scope": ["string", "constant.numeric"],
      "settings": { "foreground": "#F7A56B" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#F2EDE7" }
    },
    {
      "scope": ["entity.name.function", "support.function", "variable"],
      "settings": { "foreground": "#F2EDE7" }
    },
    {
      "scope": ["entity.name.tag", "keyword.control"],
      "settings": { "foreground": "#F7A56B" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#C98858" }
    },
    {
      "scope": ["invalid"],
      "settings": { "foreground": "#F2EDE7" }
    }
  ]
}
