    "editor.lineHighlightBackground": "#1C1C1C",
    "editor.selectionBackground": "#D4894A44",
    "editor.inactiveSelectionBackground": "#D4894A28",
    "editorCursor.foreground": "#E0A06A",
    "editorLineNumber.foreground": "#8F5A32",
    "editorLineNumber.activeForeground": "#D4894A",
    "editorWidget.background": "#1C1C1C",
    "editorWidget.border": "#333333",
    "editorSuggestWidget.background": "#1C1C1C",
    "editorSuggestWidget.selectedBackground": "#D4894A",
    "editorSuggestWidget.selectedForeground": "#141414",
    "editorSuggestWidget.foreground": "#EDE8E3",
    "editorSuggestWidget.highlightForeground": "#E0A06A",

    "sideBar.background": "#1C1C1C",
    "sideBar.foreground": "#EDE8E3",
    "sideBar.border": "#333333",
    "sideBarTitle.foreground": "#D4894A",
    "sideBarSectionHeader.background": "#1C1C1C",
    "sideBarSectionHeader.foreground": "#A39E98",

    "activityBar.background": "#121212",
    "activityBar.foreground": "#D4894A",
    "activityBar.inactiveForeground": "#8F5A32",
    "activityBar.border": "#333333",
    "activityBarBadge.background": "#D4894A",
    "activityBarBadge.foreground": "#141414",

    "titleBar.activeBackground": "#121212",
    "titleBar.activeForeground": "#EDE8E3",
    "titleBar.inactiveBackground": "#121212",
    "titleBar.inactiveForeground": "#A39E98",
    "titleBar.border": "#333333",

    "statusBar.background": "#121212",
    "statusBar.foreground": "#D4894A",
    "statusBar.border": "#333333",
    "statusBar.noFolderBackground": "#121212",
    "statusBarItem.hoverBackground": "#262626",
    "statusBarItem.prominentBackground": "#D4894A",
    "statusBarItem.prominentForeground": "#141414",

    "tab.activeBackground": "#1C1C1C",
    "tab.activeForeground": "#EDE8E3",
    "tab.activeBorderTop": "#D4894A",
    "tab.inactiveBackground": "#141414",
    "tab.inactiveForeground": "#A39E98",
    "tab.border": "#333333",
    "editorGroupHeader.tabsBackground": "#141414",

    "panel.background": "#141414",
    "panel.border": "#333333",
    "panelTitle.activeForeground": "#D4894A",
    "panelTitle.inactiveForeground": "#A39E98",

    "input.background": "#262626",
    "input.foreground": "#EDE8E3",
    "input.border": "#333333",
    "input.placeholderForeground": "#8F5A32",
    "inputOption.activeBorder": "#D4894A",

    "button.background": "#D4894A",
    "button.foreground": "#141414",
    "button.hoverBackground": "#E0A06A",
    "button.secondaryBackground": "#262626",
    "button.secondaryForeground": "#EDE8E3",
    "button.secondaryHoverBackground": "#333333",

    "list.activeSelectionBackground": "#D4894A33",
    "list.activeSelectionForeground": "#EDE8E3",
    "list.hoverBackground": "#262626",
    "list.inactiveSelectionBackground": "#262626",
    "list.focusBackground": "#D4894A28",
    "list.highlightForeground": "#E0A06A",

    "scrollbarSlider.background": "#D4894A22",
    "scrollbarSlider.hoverBackground": "#D4894A44",
    "scrollbarSlider.activeBackground": "#E0A06A88",

    "badge.background": "#D4894A",
    "badge.foreground": "#141414",
    "progressBar.background": "#D4894A",

    "terminal.background": "#141414",
    "terminal.foreground": "#EDE8E3",
    "terminal.ansiBlack": "#141414",
    "terminal.ansiRed": "#E0A06A",
    "terminal.ansiGreen": "#A39E98",
    "terminal.ansiYellow": "#E0A06A",
    "terminal.ansiBlue": "#D4894A",
    "terminal.ansiMagenta": "#D4894A",
    "terminal.ansiCyan": "#A39E98",
    "terminal.ansiWhite": "#EDE8E3",
    "terminalCursor.foreground": "#E0A06A",

    "widget.shadow": "#00000055",
    "dropdown.background": "#1C1C1C",
    "dropdown.foreground": "#EDE8E3",
    "dropdown.border": "#333333",

    "checkbox.background": "#262626",
    "checkbox.foreground": "#D4894A",
    "checkbox.border": "#333333",

    "peekView.border": "#D4894A",
    "peekViewEditor.background": "#1C1C1C",
    "peekViewResult.background": "#141414",
    "peekViewTitle.background": "#1C1C1C"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#D4894A" }
    },
    {
      "scope": ["string", "constant.numeric"],
      "settings": { "foreground": "#E0A06A" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#EDE8E3" }
    },
    {
      "scope": ["entity.name.function", "support.function", "variable"],
      "settings": { "foreground": "#EDE8E3" }
    },
    {
      "scope": ["entity.name.tag", "keyword.control"],
      "settings": { "foreground": "#D4894A" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#E0A06A" }
    },
    {
      "scope": ["invalid"],
      "settings": { "foreground": "#EDE8E3" }
    }
  ]
}
