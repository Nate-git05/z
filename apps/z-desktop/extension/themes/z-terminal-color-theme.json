    "widget.shadow": "#00000055",
    "dropdown.background": "#161412",
    "dropdown.foreground": "#F2EDE7",
    "dropdown.border": "#2A2622",

    "checkbox.background": "#1E1B18",
    "checkbox.foreground": "#F7A56B",
