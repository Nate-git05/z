    "button.hoverBackground": "#C98858",
    "button.secondaryBackground": "#1E1B18",
    "button.secondaryForeground": "#F2EDE7",
    "button.secondaryHoverBackground": "#2A2622",

    "list.activeSelectionBackground": "#F7A56B22",
