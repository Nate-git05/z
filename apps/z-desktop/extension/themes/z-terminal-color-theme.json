{
  "name": "Z Terminal",
  "type": "dark",
  "colors": {
    "focusBorder": "#C96A2B",
    "foreground": "#F5F5F5",
    "descriptionForeground": "#D8D8D8",
    "errorForeground": "#E07830",
    "icon.foreground": "#C96A2B",

    "editor.background": "#0A0A0A",
